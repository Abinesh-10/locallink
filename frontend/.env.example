# Point this at your deployed backend (Render/Railway/VPS) or local backend.
# API calls from the Lovable preview will fail until this is set to a
# reachable URL — see the doc's "Important runtime note".
VITE_API_URL=http://localhost:4000

# Used by the Socket.IO client (chat/notifications, wired but unused until Phase 7).
VITE_SOCKET_URL=http://localhost:4000
