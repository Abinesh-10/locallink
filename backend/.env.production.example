# ════════════════════════════════════════════════════════════════════════
#  LocalLink — Production Environment Variables
#  Copy this file's values into your Railway service's environment tab.
#  DO NOT commit this file with real values filled in.
# ════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────────────
# Get from: neon.tech → Project → Connection String
#        or: railway.app → Postgres plugin → Connect tab
#        or: supabase.com → Project → Settings → Database → Connection string
# IMPORTANT: after connecting, run as superuser once:
#   CREATE EXTENSION IF NOT EXISTS pgcrypto;
#   CREATE EXTENSION IF NOT EXISTS citext;
#   CREATE EXTENSION IF NOT EXISTS cube;
#   CREATE EXTENSION IF NOT EXISTS earthdistance;
#   CREATE EXTENSION IF NOT EXISTS btree_gist;
DATABASE_URL=postgresql://user:password@host:5432/dbname
PG_SSL=true

# ── JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" ──
JWT_ACCESS_SECRET=<64-char-random-hex>
JWT_REFRESH_SECRET=<64-char-random-hex>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=ll_refresh_token

# ── CORS ─────────────────────────────────────────────────────────────────
# Set to your production frontend domain (no trailing slash)
CORS_ORIGINS=https://yourdomain.com

# ── MSG91 — Sign up at msg91.com ─────────────────────────────────────────
# Dashboard → API → Auth Key
MSG91_AUTH_KEY=<your-auth-key>
# Dashboard → SMS → OTP → Template ID
MSG91_TEMPLATE_ID=<your-template-id>
MSG91_SENDER_ID=LCLLNK
# Dashboard → Webhooks → set secret
MSG91_WEBHOOK_SECRET=<your-webhook-secret>

# ── SMTP — Sign up at brevo.com (free: 300 emails/day) ───────────────────
# SMTP & API → SMTP → Generate SMTP key
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<your-brevo-login-email>
SMTP_PASS=<your-brevo-smtp-key>
SMTP_FROM="LocalLink <no-reply@yourdomain.com>"

# ── Google OAuth — console.cloud.google.com ──────────────────────────────
# APIs & Services → Credentials → Create OAuth client ID (Web application)
# Authorized redirect URI: https://your-backend.railway.app/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>
GOOGLE_CALLBACK_URL=https://your-backend.railway.app/api/v1/auth/google/callback
FRONTEND_OAUTH_REDIRECT_URL=https://yourdomain.com/auth/oauth-success

# ── Cloudinary — cloudinary.com (free: 25 GB) ────────────────────────────
# Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── KYC Provider (optional — manual admin review works without this) ──────
KYC_PROVIDER=surepass
KYC_API_KEY=<your-surepass-key>
KYC_API_BASE_URL=https://kyc-api.surepass.io
KYC_WEBHOOK_SECRET=<your-kyc-webhook-secret>

# ── Redis (optional — enables Socket.IO multi-instance scaling) ───────────
# Railway Postgres plugin → Add Redis → Connect tab
REDIS_URL=

# ── Misc (safe to leave as-is) ───────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=15
