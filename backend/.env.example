# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────
# Local docker-compose default. Replace with Neon/Supabase/RDS URL in prod.
DATABASE_URL=postgresql://locallink:locallink@localhost:5432/locallink
PG_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_access
JWT_REFRESH_SECRET=change_this_to_a_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=ll_refresh_token

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list. Include your Lovable preview URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MSG91 (Phone OTP + SOS SMS) ──────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_otp_template_id
MSG91_SENDER_ID=LCLLNK
MSG91_WEBHOOK_SECRET=your_msg91_webhook_secret

# ── SMTP (Email OTP / password reset) ───────────────────────────────
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM="LocalLink <no-reply@locallink.app>"

# ── Google OAuth 2.0 ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
# Where to redirect the browser after a successful Google login
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:5173/auth/oauth-success

# ── Cloudinary (profile photos; later: listings, chat images) ───────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── KYC Provider (used from Phase 2 onward; present now for schema) ─
KYC_PROVIDER=surepass
KYC_API_KEY=your_kyc_provider_key
KYC_API_BASE_URL=https://kyc-api.surepass.io
KYC_WEBHOOK_SECRET=your_kyc_webhook_secret

# ── Redis (optional; Socket.IO adapter + rate-limit store) ──────────
REDIS_URL=

# ── Misc ──────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=15
